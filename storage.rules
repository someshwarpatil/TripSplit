rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Trip cover images and receipts: any authenticated user can read; any authenticated user can write.
    // Storage rules can't query Firestore for membership, so we rely on the path being unguessable
    // (trip IDs are random) and on Firestore security rules to gate the URLs.
    match /trips/{tripId}/{allPaths=**} {
      allow read, write: if request.auth != null
        && (request.resource == null
            || (request.resource.size < 10 * 1024 * 1024
                && request.resource.contentType.matches('image/.*')));
    }

    // User-scoped uploads (e.g., temp scans before expense save).
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && (request.resource == null
            || (request.resource.size < 10 * 1024 * 1024
                && request.resource.contentType.matches('image/.*')));
    }
  }
}
